# 應用程式設定
APP_ENV=development                              # 環境：development 或 production
SECRET_KEY=your_super_secret_key_change_this     # JWT 簽名密鑰（請換成隨機字串）
ACCESS_TOKEN_EXPIRE_MINUTES=10080                # JWT 有效期：7 天

# PostgreSQL 資料庫連線（本地 Docker）
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5437/quant_db

# 前端來源（CORS 白名單，多個用逗號分隔）
ALLOWED_ORIGINS=http://localhost:5173

# 富果 API 金鑰（向富果申請後填入）
FUGLE_API_KEY=your_fugle_api_key
FUGLE_API_SECRET=your_fugle_api_secret

# Anthropic Claude API 金鑰
ANTHROPIC_API_KEY=your_anthropic_api_key

# 台灣證交所 API（抓取法人數據，免費，不需申請）
TWSE_BASE_URL=https://www.twse.com.tw/exchangeReport
